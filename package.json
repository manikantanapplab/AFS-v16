{
  "name": "agency-frontend-system",
  "version": "16.0.0",
  "description": "Agency Frontend System (AFS) v16 \u2014 frontend delivery system for agency teams",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel watch:pug watch:sass watch:js watch:assets serve",
    "serve": "vite",
    "watch:pug": "node system/build-pug.mjs --watch",
    "watch:sass": "node system/build-sass.mjs --watch",
    "copy:js": "copyfiles -u 2 \"src/js/**/*\" dist/assets/js",
    "build:pug": "node system/build-pug.mjs",
    "build:sass": "node system/build-sass.mjs --compressed",
    "build": "npm run build:pug && npm run build:sass && npm run copy:js && npm run copy:assets",
    "build:prod": "npm run build && node system/postcss-build.mjs && node system/run-critical.mjs",
    "new": "node system/new-component.mjs",
    "page": "node system/new-page.mjs",
    "showcase": "npm run build && node system/build-showcase.mjs",
    "doctor": "node system/afs-doctor.mjs",
    "format": "prettier --write \"src/**/*.{scss,js,pug}\"",
    "build:sass:dev": "node system/build-sass.mjs",
    "build:be": "npm run build:pug && npm run build:sass && npm run copy:js",
    "watch:js": "node system/watch-js.mjs",
    "copy:assets": "copyfiles -u 2 \"src/assets/**/*\" dist/assets",
    "watch:assets": "node system/watch-assets.mjs"
  },
  "dependencies": {
    "alpinejs": "^3.14.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "cssnano": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "pug-cli": "^1.0.0-alpha6",
    "sass": "^1.77.0",
    "vite": "^6.0.0"
  }
}
